{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-pm.local/schemas/patch.schema.json",
  "title": "Artifact Patch",
  "description": "Executable patch that mutates structured artifacts without full regeneration.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "requirementId",
    "target",
    "operations",
    "generatedAt",
    "generator"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^patch-[0-9]{3,}$"
    },
    "requirementId": {
      "type": "string",
      "pattern": "^req-[0-9]{3,}$"
    },
    "sourceReviewId": {
      "type": "string",
      "pattern": "^review-[0-9]{3,}$"
    },
    "sourceChatMessageId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifactType"
      ],
      "properties": {
        "artifactType": {
          "type": "string",
          "enum": [
            "clarify",
            "product_model",
            "prd",
            "wireframe",
            "annotation",
            "ui"
          ]
        },
        "artifactPath": {
          "type": "string",
          "maxLength": 300
        },
        "pageId": {
          "type": "string",
          "maxLength": 120
        }
      }
    },
    "summary": {
      "type": "string",
      "maxLength": 2000
    },
    "generator": {
      "type": "string",
      "enum": [
        "ai",
        "rule_engine",
        "manual"
      ]
    },
    "model": {
      "type": "string",
      "maxLength": 100
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "operations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/operation"
      }
    }
  },
  "$defs": {
    "operation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "op",
        "path"
      ],
      "properties": {
        "op": {
          "type": "string",
          "enum": [
            "add",
            "replace",
            "remove",
            "move",
            "link_task",
            "resolve_annotation"
          ]
        },
        "path": {
          "type": "string",
          "minLength": 1,
          "maxLength": 300,
          "description": "JSON pointer or logical domain path such as /functionalRequirements/2 or annotations.page-home-annotation-1"
        },
        "from": {
          "type": "string",
          "maxLength": 300
        },
        "value": {
          "type": [
            "string",
            "number",
            "boolean",
            "object",
            "array",
            "null"
          ]
        },
        "reason": {
          "type": "string",
          "maxLength": 2000
        },
        "guard": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "equals": {
              "type": [
                "string",
                "number",
                "boolean",
                "null"
              ]
            },
            "exists": {
              "type": "boolean"
            }
          }
        }
      }
    }
  }
}
