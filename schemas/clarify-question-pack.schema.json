{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-pm.local/schemas/clarify-question-pack.schema.json",
  "title": "Clarify Question Pack",
  "description": "Structured clarify questionnaire used to gate requirement progression from vague intake into product modeling.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "requirementId",
    "domain",
    "version",
    "generatedAt",
    "generator",
    "status",
    "gating",
    "questions"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^clarify-pack-[0-9]{3,}$"
    },
    "requirementId": {
      "type": "string",
      "pattern": "^req-[0-9]{3,}$"
    },
    "domain": {
      "type": "string",
      "minLength": 1,
      "maxLength": 80
    },
    "version": {
      "type": "string",
      "minLength": 1,
      "maxLength": 40
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "generator": {
      "type": "string",
      "enum": [
        "ai",
        "template",
        "manual"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "in_progress",
        "ready_for_review",
        "approved",
        "blocked"
      ]
    },
    "summary": {
      "type": "string",
      "maxLength": 2000
    },
    "gating": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "requiredFieldKeys",
        "completionScore",
        "isSatisfied"
      ],
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "hard_block",
            "warning_only"
          ]
        },
        "requiredFieldKeys": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/fieldKey"
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "missingFieldKeys": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/fieldKey"
          },
          "uniqueItems": true,
          "default": []
        },
        "completionScore": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "isSatisfied": {
          "type": "boolean"
        },
        "blockingReason": {
          "type": "string",
          "maxLength": 2000
        }
      }
    },
    "questions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/question"
      }
    },
    "answeredFieldMap": {
      "type": "object",
      "additionalProperties": {
        "type": [
          "string",
          "number",
          "boolean",
          "object",
          "array",
          "null"
        ]
      },
      "default": {}
    },
    "reviewNotes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/reviewNote"
      },
      "default": []
    }
  },
  "$defs": {
    "fieldKey": {
      "type": "string",
      "pattern": "^[a-z][a-zA-Z0-9_.-]{1,80}$"
    },
    "question": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "fieldKey",
        "title",
        "prompt",
        "required",
        "answerFormat",
        "status"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^cq-[0-9]{3,}$"
        },
        "fieldKey": {
          "$ref": "#/$defs/fieldKey"
        },
        "title": {
          "type": "string",
          "minLength": 1,
          "maxLength": 120
        },
        "prompt": {
          "type": "string",
          "minLength": 1,
          "maxLength": 2000
        },
        "whyNeeded": {
          "type": "string",
          "maxLength": 1000
        },
        "required": {
          "type": "boolean"
        },
        "priority": {
          "type": "string",
          "enum": [
            "critical",
            "high",
            "medium",
            "low"
          ],
          "default": "medium"
        },
        "answerFormat": {
          "type": "string",
          "enum": [
            "short_text",
            "long_text",
            "single_select",
            "multi_select",
            "number",
            "boolean",
            "json"
          ]
        },
        "suggestedOptions": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 200
          },
          "uniqueItems": true,
          "default": []
        },
        "appliesWhen": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/condition"
          },
          "default": []
        },
        "answer": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "number"
            },
            {
              "type": "boolean"
            },
            {
              "type": "array"
            },
            {
              "type": "object"
            },
            {
              "type": "null"
            }
          ]
        },
        "answerSource": {
          "type": "string",
          "enum": [
            "user",
            "ai_inferred",
            "manual_editor"
          ]
        },
        "status": {
          "type": "string",
          "enum": [
            "unanswered",
            "answered",
            "assumed",
            "not_applicable",
            "needs_review"
          ]
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "condition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "fieldKey",
        "operator",
        "value"
      ],
      "properties": {
        "fieldKey": {
          "$ref": "#/$defs/fieldKey"
        },
        "operator": {
          "type": "string",
          "enum": [
            "equals",
            "not_equals",
            "includes",
            "exists"
          ]
        },
        "value": {
          "type": [
            "string",
            "number",
            "boolean",
            "null"
          ]
        }
      }
    },
    "reviewNote": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "severity",
        "message",
        "createdAt"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^clarify-note-[0-9]{3,}$"
        },
        "severity": {
          "type": "string",
          "enum": [
            "blocker",
            "warning",
            "info"
          ]
        },
        "message": {
          "type": "string",
          "minLength": 1,
          "maxLength": 2000
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    }
  }
}
