{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-pm.local/schemas/skill.schema.json",
  "title": "Skill",
  "description": "Reusable domain or workflow capability pack for AI PM.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "name",
    "version",
    "description",
    "status",
    "triggers",
    "stages"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]{1,63}$"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "description": {
      "type": "string",
      "minLength": 1,
      "maxLength": 2000
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "experimental",
        "disabled",
        "deprecated"
      ]
    },
    "author": {
      "type": "string",
      "maxLength": 120
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 50
      },
      "uniqueItems": true,
      "default": []
    },
    "triggers": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 80
      },
      "default": []
    },
    "stages": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "captured",
          "triaged",
          "clarifying",
          "modeled",
          "prd_ready",
          "wireframe_ready",
          "ui_ready",
          "reviewing",
          "approved",
          "archived",
          "intake",
          "scoring",
          "prd",
          "prd_validation",
          "competitor_analysis",
          "wireframe",
          "wireframe_annotation",
          "ui",
          "task"
        ]
      },
      "minItems": 1
    },
    "inputs": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "outputs": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "files": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "manifest": {
          "type": "string"
        },
        "prompt": {
          "type": "string"
        },
        "template": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "config": {
      "type": "object",
      "additionalProperties": true,
      "default": {}
    }
  }
}
