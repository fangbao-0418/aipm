{
  "id": "prd-validator",
  "name": "PRD Validator",
  "version": "0.1.0",
  "description": "Validate PRD completeness, consistency, risks, and missing constraints before downstream generation.",
  "status": "active",
  "author": "ai-pm",
  "tags": [
    "prd",
    "validation",
    "quality"
  ],
  "triggers": [
    "prd validation",
    "automatic quality check",
    "risk review"
  ],
  "stages": [
    "prd",
    "prd_validation",
    "reviewing"
  ],
  "inputs": [
    "product-model.json",
    "prd.md"
  ],
  "outputs": [
    "prd-validation.json"
  ],
  "files": {
    "manifest": "skill.json",
    "notes": "README.md"
  },
  "config": {
    "defaultSeverityThreshold": "medium"
  }
}
