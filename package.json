{
  "name": "ai-pm",
  "version": "0.1.0",
  "private": true,
  "description": "Local-first AI product management CLI and workspace.",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev:cli": "tsx src/cli/bin.ts",
    "dev:workspace": "tsx src/studio/server.ts",
    "dev:workspace:server": "tsx src/studio/server.ts",
    "dev:workspace:web": "npm --prefix UI run dev",
    "dev:studio": "npm run dev:workspace",
    "dev:studio:server": "npm run dev:workspace:server",
    "dev:studio:web": "npm run dev:workspace:web",
    "check": "tsc --noEmit && tsc -p studio/tsconfig.json --noEmit",
    "test": "node --import tsx --test src/application/workspace/chat-rules.test.ts",
    "build:server": "tsc -p tsconfig.json",
    "build:workspace": "npm --prefix UI run build",
    "build:studio": "npm run build:workspace",
    "build": "npm run build:server && npm run build:workspace",
    "start:cli": "node dist/cli/bin.js",
    "start:workspace": "node dist/studio/server.js",
    "start:studio": "npm run start:workspace"
  },
  "bin": {
    "aipm": "./dist/cli/bin.js"
  },
  "dependencies": {
    "@fastify/multipart": "^10.0.0",
    "@fastify/static": "^8.1.1",
    "commander": "^13.1.0",
    "fastify": "^5.2.1",
    "mammoth": "^1.12.0",
    "pdf-parse": "^2.4.5",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "word-extractor": "^1.0.4",
    "xlsx": "^0.18.5",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vite": "^6.2.0"
  }
}
